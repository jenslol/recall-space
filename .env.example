# Recall Space — Configuration
# Copy to .env and edit.

# AI worker URL (your gaming PC / Mac Mini running Ollama + Whisper)
# Leave empty to skip AI processing (capture-only mode)
AI_WORKER_URL=http://192.168.86.28:8401

# API key for protecting the API endpoints
# Leave empty for no authentication (LAN-only use)
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Database and uploads (inside container)
DATABASE_PATH=/app/data/recall.db
UPLOADS_PATH=/app/uploads

# Processor poll interval (seconds)
POLL_INTERVAL=10

# ntfy push notifications
NTFY_URL=http://ntfy:80
NTFY_TOPIC=recall-space

# Base URL for links in notifications (your external URL)
# e.g. http://192.168.86.35:8400 or https://recall.tarnished.dk
BASE_URL=http://192.168.86.35:8400
